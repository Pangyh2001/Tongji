      "use_margin_weighting": false,
      "margin_alpha": 2.0,
      "margin_sigma": 0.08,
      "curvature_weight": 0.0,
      "normal_weight": 0.0,
      "roughness_knn": 6
    },
    "improved": {
      "use_margin_weighting": true,
      "margin_alpha": 2.0,
      "margin_sigma": 0.08,
      "curvature_weight": 0.1,
      "normal_weight": 0.05,
      "roughness_knn": 6
    }
  },
  "metrics": {
    "fscore_threshold_mm": 0.3
  }
}
