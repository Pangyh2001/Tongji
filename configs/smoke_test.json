    "latent_dim": 96,
    "dropout": 0.05,
    "max_offset": 1.0,
    "encoder_knn": 8,
    "decoder_knn": 8
  },
  "training": {
    "epochs": 2,
    "batch_size": 1,
    "learning_rate": 0.0007,
    "weight_decay": 0.0001,
