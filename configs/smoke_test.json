{
  "seed": 7,
  "device": "auto",
  "prep_points": 512,
  "opposing_points": 512,
  "crown_points": 512,
  "margin_points": 64,
  "template": {
    "num_latitude_rings": 15,
    "num_longitude_segments": 16,
    "theta_max_radians": 2.55
